@prefix ex:   <http://example.org/> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .

########## DECLARAÇÃO DAS CLASSES ##########

ex:Campeonato    a rdfs:Class ; rdfs:label "Campeonato de Futebol"@pt .
ex:Clube         a rdfs:Class ; rdfs:label "Clube de Futebol"@pt .
ex:Estadio       a rdfs:Class ; rdfs:label "Estádio de Futebol"@pt .
ex:Pessoa        a rdfs:Class ; rdfs:label "Pessoa do Contexto Esportivo"@pt .

ex:Jogador       rdfs:subClassOf ex:Pessoa ; rdfs:label "Jogador"@pt .
ex:Treinador     rdfs:subClassOf ex:Pessoa ; rdfs:label "Treinador"@pt .
ex:Arbitro       rdfs:subClassOf ex:Pessoa ; rdfs:label "Árbitro de Futebol"@pt .

ex:Partida       a rdfs:Class ; rdfs:label "Partida de Futebol Oficial"@pt .
ex:EventoJogo    a rdfs:Class ; rdfs:label "Evento Ocorrido em Partida"@pt .
ex:Gol           rdfs:subClassOf ex:EventoJogo .
ex:Cartao        rdfs:subClassOf ex:EventoJogo .
ex:Substituicao  rdfs:subClassOf ex:EventoJogo .

########## PROPRIEDADES (CONSTRUTORES E REGRAS) ##########

ex:nome a rdf:Property ; rdf:type owl:FunctionalProperty .
ex:estadio a rdf:Property ; rdf:type owl:FunctionalProperty .
ex:data a rdf:Property ; rdf:type owl:FunctionalProperty .
ex:horario a rdf:Property ; rdf:type owl:FunctionalProperty .
ex:publico a rdf:Property ; rdf:type owl:FunctionalProperty .
ex:renda a rdf:Property ; rdf:type owl:FunctionalProperty .
ex:arbitroPrincipal a rdf:Property ; rdf:type owl:FunctionalProperty .

ex:campeao a rdf:Property ; rdf:type owl:FunctionalProperty .
ex:viceCampeao a rdf:Property ; rdf:type owl:FunctionalProperty .
ex:artilheiro a rdf:Property .
ex:melhorJogador a rdf:Property ; rdf:type owl:FunctionalProperty .
ex:melhorTreinador a rdf:Property ; rdf:type owl:FunctionalProperty .

ex:mandante a rdf:Property ; rdf:type owl:FunctionalProperty .
ex:visitante a rdf:Property ; rdf:type owl:FunctionalProperty .
ex:golsMandante a rdf:Property ; rdf:type owl:FunctionalProperty .
ex:golsVisitante a rdf:Property ; rdf:type owl:FunctionalProperty .
ex:golsPenaltisMandante a rdf:Property ; rdf:type owl:FunctionalProperty .
ex:golsPenaltisVisitante a rdf:Property ; rdf:type owl:FunctionalProperty .

ex:tecnicoMandante a rdf:Property ; rdf:type owl:FunctionalProperty .
ex:tecnicoVisitante a rdf:Property ; rdf:type owl:FunctionalProperty .
ex:temEvento a rdf:Property .
ex:minuto a rdf:Property ; rdf:type owl:FunctionalProperty .
ex:envolveJogador a rdf:Property .
ex:saiJogador a rdf:Property ; rdf:type owl:FunctionalProperty .
ex:entraJogador a rdf:Property ; rdf:type owl:FunctionalProperty .
ex:tipoCartao a rdf:Property ; rdf:type owl:FunctionalProperty .

# Propriedade simétrica obrigatória pelas regras estruturais
ex:rivalDe a rdf:Property ; rdf:type owl:SymmetricProperty .

########## ENTIDADES MACRO E ESTÁDIOS ##########

ex:Cariocao2026 a ex:Campeonato ;
    rdfs:label "Campeonato Carioca de Futebol 2026"@pt , "2026 Carioca Football Championship"@en ;
    ex:campeao ex:Flamengo ;
    ex:viceCampeao ex:Fluminense ;
    ex:artilheiro ex:Pedro , ex:PatryckMagalhaes ;
    ex:melhorJogador ex:Fabio ;
    ex:melhorTreinador ex:Zubeldia .

ex:Maracana a ex:Estadio ; ex:nome "Estádio Jornalista Mário Filho"@pt , "Maracanã"@en .
ex:NiltonSantos a ex:Estadio ; ex:nome "Estádio Nilton Santos"@pt .

########## CLUBES E RELAÇÕES SIMÉTRICAS ##########

ex:Flamengo a ex:Clube ;
    ex:nome "Clube de Regatas do Flamengo"@pt ;
    ex:rivalDe ex:Fluminense , ex:Vasco .

ex:Fluminense a ex:Clube ;
    ex:nome "Fluminense Football Club"@pt ;
    ex:rivalDe ex:Flamengo .

ex:Vasco a ex:Clube ;
    ex:nome "Club de Regatas Vasco da Gama"@pt ;
    ex:rivalDe ex:Flamengo .

ex:Madureira a ex:Clube ;
    ex:nome "Madureira Esporte Clube"@pt .

########## COMISSÕES TÉCNICAS E ÁRBITROS ##########

ex:FilipeLuis a ex:Treinador ; ex:nome "Filipe Luís"@pt .
ex:LeonardoJardim a ex:Treinador ; ex:nome "Leonardo Jardim"@pt .
ex:Zubeldia a ex:Treinador ; ex:nome "Luis Zubeldía"@pt .
