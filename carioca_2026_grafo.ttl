########## HISTÓRICO DE PARTIDAS E SEUS MICRO-EVENTOS ##########

### 1. GRANDE FINAL (JOGO ÚNICO)
ex:Partida_Final a ex:Partida ;
    ex:mandante ex:Flamengo ;
    ex:visitante ex:Fluminense ;
    ex:golsMandante "0"^^xsd:integer ;
    ex:golsVisitante "0"^^xsd:integer ;
    ex:golsPenaltisMandante "5"^^xsd:integer ;
    ex:golsPenaltisVisitante "4"^^xsd:integer ;
    ex:estadio ex:Maracana ;
    ex:data "2026-03-08"^^xsd:date ;
    ex:horario "18:00" ;
    ex:publico "69315"^^xsd:integer ;
    ex:renda "5270903.50"^^xsd:decimal ;
    ex:arbitroPrincipal ex:BrunoArleu ;
    ex:tecnicoMandante ex:LeonardoJardim ;
    ex:tecnicoVisitante ex:Zubeldia ;
    ex:temEvento _:cf1 , _:cf2 , _:cf3 , _:cf4 , _:cf5 , _:cf6 ;
    ex:temEvento _:sf1 , _:sf2 , _:sf3 , _:sf4 , _:sf5 , _:sf6 , _:sf7 .

# Lances detalhados da Final (com minutos)
_:cf1 a ex:Cartao ; ex:tipoCartao "Amarelo" ; ex:envolveJogador ex:Rene ; ex:minuto "21"^^xsd:integer .
_:cf2 a ex:Cartao ; ex:tipoCartao "Amarelo" ; ex:envolveJogador ex:LuchoAcosta ; ex:minuto "44"^^xsd:integer .
_:cf3 a ex:Cartao ; ex:tipoCartao "Amarelo" ; ex:envolveJogador ex:Canobbio ; ex:minuto "56"^^xsd:integer .
_:cf4 a ex:Cartao ; ex:tipoCartao "Amarelo" ; ex:envolveJogador ex:SamuelLino ; ex:minuto "62"^^xsd:integer .
_:cf5 a ex:Cartao ; ex:tipoCartao "Amarelo" ; ex:envolveJogador ex:Jorginho ; ex:minuto "67"^^xsd:integer .
_:cf6 a ex:Cartao ; ex:tipoCartao "Amarelo" ; ex:envolveJogador ex:KevinSerna ; ex:minuto "92"^^xsd:integer .

_:sf1 a ex:Substituicao ; ex:saiJogador ex:GonzaloPlata ; ex:entraJogador ex:LuizAraujo ; ex:minuto "65"^^xsd:integer .
_:sf2 a ex:Substituicao ; ex:saiJogador ex:SamuelLino ; ex:entraJogador ex:BrunoHenrique ; ex:minuto "70"^^xsd:integer .
_:sf3 a ex:Substituicao ; ex:saiJogador ex:Arrascaeta ; ex:entraJogador ex:DeLaCruz ; ex:minuto "78"^^xsd:integer .
_:sf4 a ex:Substituicao ; ex:saiJogador ex:ErickPulgar ; ex:entraJogador ex:Jorginho ; ex:minuto "67"^^xsd:integer .
_:sf5 a ex:Substituicao ; ex:saiJogador ex:Hercules ; ex:entraJogador ex:Ganso ; ex:minuto "60"^^xsd:integer .
_:sf6 a ex:Substituicao ; ex:saiJogador ex:Canobbio ; ex:entraJogador ex:Savarino ; ex:minuto "72"^^xsd:integer .
_:sf7 a ex:Substituicao ; ex:saiJogador ex:Rene ; ex:entraJogador ex:GuilhermeArana ; ex:minuto "80"^^xsd:integer .


