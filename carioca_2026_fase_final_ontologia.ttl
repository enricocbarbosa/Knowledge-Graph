@prefix ex:   <http://example.org/carioca2026/> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .

############################################################
########################## CLASSES ##########################
############################################################

ex:Campeonato      a rdfs:Class .
ex:Fase            a rdfs:Class .
ex:Rodada          a rdfs:Class .
ex:Jogo            a rdfs:Class .
ex:Time            a rdfs:Class .
ex:Jogador         a rdfs:Class .
ex:Tecnico         a rdfs:Class .
ex:Arbitro         a rdfs:Class .
ex:Estadio         a rdfs:Class .
ex:Gol             a rdfs:Class .
ex:Cartao          a rdfs:Class .
ex:Substituicao    a rdfs:Class .
ex:Penalti         a rdfs:Class .
ex:Artilharia      a rdfs:Class .
ex:Premiacao       a rdfs:Class .
ex:Selecao         a rdfs:Class .
ex:Evento          a rdfs:Class .

############################################################
####################### PROPRIEDADES #######################
############################################################

ex:temFase a rdf:Property ;
    rdfs:domain ex:Campeonato ;
    rdfs:range ex:Fase .

ex:temRodada a rdf:Property ;
    rdfs:domain ex:Jogo ;
    rdfs:range ex:Rodada .

ex:temJogo a rdf:Property ;
    rdfs:domain ex:Campeonato ;
    rdfs:range ex:Jogo .

ex:mandante a rdf:Property ;
    rdfs:domain ex:Jogo ;
    rdfs:range ex:Time .

ex:visitante a rdf:Property ;
    rdfs:domain ex:Jogo ;
    rdfs:range ex:Time .

ex:temEstadio a rdf:Property ;
    rdfs:domain ex:Jogo ;
    rdfs:range ex:Estadio ;
    a owl:FunctionalProperty .

ex:temTecnico a rdf:Property ;
    rdfs:domain ex:Time ;
    rdfs:range ex:Tecnico ;
    a owl:FunctionalProperty .

ex:possuiJogador a rdf:Property ;
    rdfs:domain ex:Time ;
    rdfs:range ex:Jogador .

ex:atuaPor a rdf:Property ;
    rdfs:domain ex:Jogador ;
    rdfs:range ex:Time .

ex:temArbitro a rdf:Property ;
    rdfs:domain ex:Jogo ;
    rdfs:range ex:Arbitro ;
    a owl:FunctionalProperty .

ex:temAssistente1 a rdf:Property ;
    rdfs:domain ex:Jogo ;
    rdfs:range ex:Arbitro .

ex:temAssistente2 a rdf:Property ;
    rdfs:domain ex:Jogo ;
    rdfs:range ex:Arbitro .

ex:temVAR a rdf:Property ;
    rdfs:domain ex:Jogo ;
    rdfs:range ex:Arbitro .

ex:temAVAR1 a rdf:Property ;
    rdfs:domain ex:Jogo ;
    rdfs:range ex:Arbitro .

ex:temAVAR2 a rdf:Property ;
    rdfs:domain ex:Jogo ;
    rdfs:range ex:Arbitro .

ex:dataJogo a rdf:Property ;
    rdfs:domain ex:Jogo ;
    rdfs:range xsd:date ;
    a owl:FunctionalProperty .

ex:horaJogo a rdf:Property ;
    rdfs:domain ex:Jogo ;
    rdfs:range xsd:time ;
    a owl:FunctionalProperty .

ex:placarMandante a rdf:Property ;
    rdfs:domain ex:Jogo ;
    rdfs:range xsd:integer ;
    a owl:FunctionalProperty .

ex:placarVisitante a rdf:Property ;
    rdfs:domain ex:Jogo ;
    rdfs:range xsd:integer ;
    a owl:FunctionalProperty .

ex:agregadoMandante a rdf:Property ;
    rdfs:domain ex:Jogo ;
    rdfs:range xsd:integer .

ex:agregadoVisitante a rdf:Property ;
    rdfs:domain ex:Jogo ;
    rdfs:range xsd:integer .

ex:publico a rdf:Property ;
    rdfs:domain ex:Jogo ;
    rdfs:range xsd:integer .

ex:renda a rdf:Property ;
    rdfs:domain ex:Jogo ;
    rdfs:range xsd:decimal .

ex:temGol a rdf:Property ;
    rdfs:domain ex:Jogo ;
    rdfs:range ex:Gol .

ex:marcouGol a rdf:Property ;
    rdfs:domain ex:Gol ;
    rdfs:range ex:Jogador .

ex:emFavorDe a rdf:Property ;
    rdfs:domain ex:Gol ;
    rdfs:range ex:Time .

ex:contra a rdf:Property ;
    rdfs:domain ex:Evento ;
    rdfs:range ex:Time .

ex:tipoGol a rdf:Property ;
    rdfs:domain ex:Gol ;
    rdfs:range rdfs:Literal .

ex:temCartao a rdf:Property ;
    rdfs:domain ex:Jogo ;
    rdfs:range ex:Cartao .

ex:recebeuCartao a rdf:Property ;
    rdfs:domain ex:Cartao ;
    rdfs:range ex:Jogador .

ex:tipoCartao a rdf:Property ;
    rdfs:domain ex:Cartao ;
    rdfs:range rdfs:Literal .

ex:motivo a rdf:Property ;
    rdfs:domain ex:Cartao ;
    rdfs:range rdfs:Literal .

ex:temSubstituicao a rdf:Property ;
    rdfs:domain ex:Jogo ;
    rdfs:range ex:Substituicao .

ex:entrou a rdf:Property ;
    rdfs:domain ex:Substituicao ;
    rdfs:range ex:Jogador .

ex:saiu a rdf:Property ;
    rdfs:domain ex:Substituicao ;
    rdfs:range ex:Jogador .

ex:temPenalti a rdf:Property ;
    rdfs:domain ex:Jogo ;
    rdfs:range ex:Penalti .

ex:resultado a rdf:Property ;
    rdfs:domain ex:Penalti ;
    rdfs:range rdfs:Literal .

ex:ocorreuNoMinuto a rdf:Property ;
    rdfs:domain ex:Evento ;
    rdfs:range xsd:integer .

ex:ocorreuNaParte a rdf:Property ;
    rdfs:domain ex:Evento ;
    rdfs:range rdfs:Literal .

ex:classificou a rdf:Property ;
    rdfs:domain ex:Time ;
    rdfs:range ex:Fase .

ex:campeao a rdf:Property ;
    rdfs:domain ex:Campeonato ;
    rdfs:range ex:Time .

ex:viceCampeao a rdf:Property ;
    rdfs:domain ex:Campeonato ;
    rdfs:range ex:Time .

ex:temArtilharia a rdf:Property ;
    rdfs:domain ex:Campeonato ;
    rdfs:range ex:Artilharia .

ex:golsNaCompeticao a rdf:Property ;
    rdfs:domain ex:Artilharia ;
    rdfs:range xsd:integer .

ex:melhorJogador a rdf:Property ;
    rdfs:domain ex:Premiacao ;
    rdfs:range ex:Jogador .

ex:revelacao a rdf:Property ;
    rdfs:domain ex:Premiacao ;
    rdfs:range ex:Jogador .

ex:melhorDefesa a rdf:Property ;
    rdfs:domain ex:Premiacao ;
    rdfs:range ex:Jogador .

ex:fairPlay a rdf:Property ;
    rdfs:domain ex:Premiacao ;
    rdfs:range ex:Time .

ex:liderRodada a rdf:Property ;
    rdfs:domain ex:Rodada ;
    rdfs:range ex:Time .

ex:posicao a rdf:Property ;
    rdfs:domain ex:Evento ;
    rdfs:range xsd:integer .

ex:pontos a rdf:Property ;
    rdfs:domain ex:Evento ;
    rdfs:range xsd:integer .

ex:vitorias a rdf:Property ;
    rdfs:domain ex:Evento ;
    rdfs:range xsd:integer .

ex:empates a rdf:Property ;
    rdfs:domain ex:Evento ;
    rdfs:range xsd:integer .

ex:derrotas a rdf:Property ;
    rdfs:domain ex:Evento ;
    rdfs:range xsd:integer .

ex:golsPro a rdf:Property ;
    rdfs:domain ex:Evento ;
    rdfs:range xsd:integer .

ex:golsContra a rdf:Property ;
    rdfs:domain ex:Evento ;
    rdfs:range xsd:integer .

ex:saldo a rdf:Property ;
    rdfs:domain ex:Evento ;
    rdfs:range xsd:integer .

ex:ordem a rdf:Property ;
    rdfs:domain ex:Penalti ;
    rdfs:range xsd:integer .

ex:rivalDe a rdf:Property ;
    a owl:SymmetricProperty ;
    rdfs:domain ex:Time ;
    rdfs:range ex:Time .

############################################################
###################### CAMPEONATO ##########################
############################################################

ex:Carioca2026_FaseFinal a ex:Campeonato ;
    rdfs:label "Campeonato Carioca 2026 — Fase Final"@pt ,
               "2026 Campeonato Carioca — Final Phase"@en ;
    ex:temFase ex:Semifinais, ex:Final ;
    ex:temJogo ex:VascoFluminenseIda, ex:FluminenseVascoVolta,
               ex:FlamengoMadureiraIda, ex:MadureiraFlamengoVolta,
               ex:Final_Flu_Fla ;
    ex:campeao ex:Flamengo ;
    ex:viceCampeao ex:Fluminense ;
    ex:temArtilharia ex:ArtilhariaPedro, ex:ArtilhariaPatryckFerreira, ex:ArtilhariaKevinSerna, ex:ArtilhariaLeoRafael,
                      ex:ArtilhariaLohan, ex:ArtilhariaRhuan, ex:ArtilhariaLucasPaqueta, ex:ArtilhariaLuanGama,
                      ex:ArtilhariaYgorCatatau, ex:ArtilhariaGutemberg, ex:ArtilhariaDenilson, ex:ArtilhariaMV,
                      ex:ArtilhariaJohnKennedy, ex:ArtilhariaRodrigoLindoso, ex:ArtilhariaGanso.

############################################################
######################### FASES ############################
############################################################

ex:Semifinais a ex:Fase ;
    rdfs:label "Semifinais"@pt , "Semifinals"@en .

ex:Final a ex:Fase ;
    rdfs:label "Final"@pt , "Final"@en .

############################################################
######################### RODADAS ##########################
############################################################

ex:RodadaSemifinalIda a ex:Rodada ;
    rdfs:label "Semifinais — Ida"@pt .

ex:RodadaSemifinalVolta a ex:Rodada ;
    rdfs:label "Semifinais — Volta"@pt .

ex:RodadaFinal a ex:Rodada ;
    rdfs:label "Final"@pt .

############################################################
########################## TIMES ###########################
############################################################

ex:Fluminense a ex:Time ;
    rdfs:label "Fluminense"@pt , "Fluminense"@en ;
    ex:temTecnico ex:LuisZubeldia ;
    ex:rivalDe ex:Flamengo, ex:VascoDaGama ;
    ex:possuiJogador ex:Fabio, ex:SamuelXavier, ex:Jemmes, ex:Freytes, ex:Rene, ex:Martinelli,
                     ex:Hercules, ex:LuchoAcosta, ex:KevinSerna, ex:Canobbio, ex:JohnKennedy,
                     ex:Guga, ex:Otavio, ex:Savarino, ex:GuilhermeArana, ex:Bernal, ex:Nonato,
                     ex:PHGanso, ex:VitorEudes, ex:MatheusReis, ex:FacundoBernal, ex:Sotelo, ex:Castillo ;
    ex:classificou ex:Final .

ex:VascoDaGama a ex:Time ;
    rdfs:label "Vasco da Gama"@pt , "Vasco da Gama"@en ;
    ex:temTecnico ex:FernandoDiniz ;
    ex:rivalDe ex:Fluminense ;
    ex:possuiJogador ex:LeoJardim, ex:PauloHenriqueVasco, ex:Saldivia, ex:RobertRenan, ex:PumaRodriguez,
                     ex:Barros, ex:TcheTche, ex:Rojas, ex:NunoMoreira, ex:AndresGomez, ex:Spinelli,
                     ex:Brenner, ex:Adson, ex:LucasPiton, ex:David, ex:PauloHenrique2, ex:Jair, ex:CauanBarros ;
    ex:classificou ex:Final .

ex:Flamengo a ex:Time ;
    rdfs:label "Flamengo"@pt , "Flamengo"@en ;
    ex:temTecnico ex:LeonardoJardim ;
    ex:rivalDe ex:Fluminense ;
    ex:possuiJogador ex:Rossi, ex:Varela, ex:LeoOrtiz, ex:LeoPereira, ex:AlexSandro, ex:ErickPulgar,
                     ex:Jorginho, ex:DeArrascaeta, ex:Carrascal, ex:SamuelLino, ex:Pedro, ex:LuizAraujo,
                     ex:EverttonAraujo, ex:Paqueta, ex:BrunoHenrique, ex:EvertonCebolinha, ex:Danilo,
                     ex:AyrtonLucas, ex:Andrew, ex:Vitao, ex:WallaceYan, ex:DeLaCruz, ex:Plata ;
    ex:classificou ex:Final .

ex:Madureira a ex:Time ;
    rdfs:label "Madureira"@pt , "Madureira"@en ;
    ex:temTecnico ex:ToninhoAndrade ;
    ex:possuiJogador ex:Neguete, ex:CauaCoutinho, ex:Marcao, ex:JeanVianna, ex:MatheusJuliao,
                     ex:Fuba, ex:RodrigoLindoso, ex:EvertonMad, ex:JuninhoMad, ex:Jaco, ex:GeovaneDiniz,
                     ex:IsaiaS, ex:AdrianoMad, ex:MichaelFashanu, ex:JoaoVitorMad, ex:ArthurJhonatan, ex:WendelMad ;
    ex:classificou ex:Final .

